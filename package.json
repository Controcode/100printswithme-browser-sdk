{
  "name": "@100printswithme/browser-sdk",
  "version": "1.0.0",
  "description": "Official Browser SDK for 100PrintsWithMe",
  "type": "module",

  "main": "./dist/100prints-sdk.umd.js",
  "module": "./dist/100prints-sdk.es.js",
  "types": "./dist/100prints-sdk.d.ts",

  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],

  "exports": {
    ".": {
      "types": "./dist/100prints-sdk.d.ts",
      "import": "./dist/100prints-sdk.es.js",
      "require": "./dist/100prints-sdk.umd.js"
    }
  },

  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/postbuild.js",
    "test": "vitest run",
    "watch": "vite build --watch"
  },

  "devDependencies": {
    "@types/jsbarcode": "^3.11.4",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "brotli-dec-wasm": "^2.3.2",
    "canvg": "^4.0.3",
    "idb-keyval": "^6.2.5",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.0.0",
    "jszip": "^3.10.1",
    "konva": "^9.3.22",
    "qrcode": "^1.5.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^3.9.1"
  },

  "license": "MIT",

  "homepage": "https://github.com/Controcode/100printswithme-browser-sdk",

  "repository": {
    "type": "git",
    "url": "git+https://github.com/Controcode/100printswithme-browser-sdk.git"
  },

  "bugs": {
    "url": "https://github.com/Controcode/100printswithme-browser-sdk/issues"
  }
}